from langchain_groq import ChatGroq
from langchain_core.prompts import PromptTemplate
from langchain_core.output_parsers import StrOutputParser
from dotenv import load_dotenv
from langchain_core.runnables import RunnableSequence, RunnableLambda, RunnablePassthrough, RunnableParallel

load_dotenv()

def word_count(text):
    #text.split convert a string of words into list
    return len(text.split())

template = PromptTemplate(
    template='Write a joke about {topic}',
    input_variables=['topic']
)

model = ChatGroq(model="openai/gpt-oss-120b")

parser = StrOutputParser()

joke_gen_chain = RunnableSequence(template, model, parser)

parallel_chain = RunnableParallel({
    'joke': RunnablePassthrough(),
     #LangChain expects everything to be a Runnable, not a normal function.
    'word_count': RunnableLambda(word_count)
})

final_chain = RunnableSequence(joke_gen_chain, parallel_chain)

result = final_chain.invoke({'topic':'AI'})

final_result = """{} \n word count - {}""".format(result['joke'], result['word_count'])
#for format see Notes.txt
print(final_result)